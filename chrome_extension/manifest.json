{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0",
  "description": "Detect phishing websites using Multi-Agent AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
"http://localhost:8000/*",
"http://127.0.0.1:8000/*"
],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}